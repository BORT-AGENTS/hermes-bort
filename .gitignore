# Local credentials — defensive; the plugin reads keys from process env only,
# but contributors must never commit a .env if they add one downstream.
.env
.env.*
!.env.example

# IDEs / editors
.idea/
.vscode/
*.swp
*~

# OS noise
.DS_Store
Thumbs.db
